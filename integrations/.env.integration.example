# ============================================================
# OpenRAG Integration Environment — Scaleway + Keycloak
# ============================================================
# Copy to .env in the openrag root directory and fill in values.
#
# Compatible with OpenRAG >= v1.1.8 (dev branch).
# Uses native OIDC auth code + PKCE flow (no oauth2-proxy needed).

# --- LLM via Scaleway Generative APIs ---
BASE_URL=https://api.scaleway.ai/<SCW_PROJECT_ID>/v1
API_KEY=<SCW_SECRET_KEY>
MODEL=mistral-small-3.2-24b-instruct-2506

# --- Embedder via Scaleway ---
EMBEDDER_BASE_URL=https://api.scaleway.ai/<SCW_PROJECT_ID>/v1
EMBEDDER_API_KEY=<SCW_SECRET_KEY>
EMBEDDER_MODEL_NAME=bge-multilingual-gemma2

# --- VLM (image captioning) via Scaleway ---
VLM_BASE_URL=https://api.scaleway.ai/<SCW_PROJECT_ID>/v1
VLM_API_KEY=<SCW_SECRET_KEY>
VLM_MODEL=pixtral-12b-2409

# --- Reranker ---
# Option A: disable (simplest)
RERANKER_ENABLED=false
# Option B: use OpenAI-compatible reranker via Scaleway
# RERANKER_ENABLED=true
# RERANKER_PROVIDER=openai
# RERANKER_MODEL=bge-reranker-v2-m3
# RERANKER_BASE_URL=https://api.scaleway.ai/<SCW_PROJECT_ID>/v1
# RERANKER_API_KEY=<SCW_SECRET_KEY>

# --- OpenRAG Ports (no collision with owuicore-main) ---
APP_PORT=8180
CHAINLIT_PORT=8190
RAY_DASHBOARD_PORT=8265
INDEXERUI_PORT=3042

# --- OIDC Authentication (native auth code + PKCE) ---
AUTH_MODE=oidc
OIDC_ENDPOINT=http://keycloak:8080/realms/openrag
OIDC_CLIENT_ID=openrag
OIDC_CLIENT_SECRET=<KEYCLOAK_CLIENT_SECRET>
OIDC_REDIRECT_URI=http://localhost:8180/auth/callback
OIDC_SCOPES=openid email profile offline_access
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OIDC_TOKEN_ENCRYPTION_KEY=<FERNET_KEY>
# Post-logout redirect (outside OpenRAG to avoid re-auth loop)
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000
# Sync claims from JWT to user record
OIDC_CLAIM_SOURCE=id_token
OIDC_CLAIM_MAPPING=display_name:name,email:email

# --- Indexer UI ---
API_BASE_URL=http://localhost:8180
INCLUDE_CREDENTIALS=false

# --- Network (connect to owuicore-main stack) ---
OWUI_NETWORK=owuicore-main_default

# --- Keycloak Sync Script (integrations/sync_keycloak_openrag.py) ---
KEYCLOAK_URL=http://localhost:8082
KEYCLOAK_REALM=openrag
KEYCLOAK_CLIENT_ID=openrag-sync
KEYCLOAK_CLIENT_SECRET=<SYNC_CLIENT_SECRET>
OPENRAG_URL=http://localhost:8180
OPENRAG_ADMIN_TOKEN=<ADMIN_TOKEN>

# --- Logging ---
LOG_LEVEL=INFO
PROMPTS_DIR=../prompts/example1
PREFERRED_URL_SCHEME=http

# --- Ray ---
RAY_DEDUP_LOGS=0
RAY_ENABLE_RECORD_ACTOR_TASK_LOGGING=1
RAY_task_retry_delay_ms=3000
RAY_ENABLE_UV_RUN_RUNTIME_ENV=0
