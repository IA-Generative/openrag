# Caddyfile — déploiement OpenRAG sur VM openrag-01-et (51.159.184.192)
# - TLS Let's Encrypt automatique (Caddy gère les renouvellements)
# - 3 vhosts (api / indexer / chat) tous sur la même IP, routage par Host
# - Le wildcard DNS *.openrag-mirai.numerique-interieur.com permet d'ajouter
#   d'autres vhosts sans toucher au DNS (ex. metrics.openrag-mirai... pour
#   Grafana plus tard).
#
# Installation sur la VM :
#   sudo apt-get install -y caddy
#   sudo cp Caddyfile.example /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Vérif TLS :
#   curl -fsSL https://api.openrag-mirai.numerique-interieur.com/health_check
#
# Adresse email pour Let's Encrypt (à remplir avec une mailing-list opérée)
{
    email ops@example.gouv.fr
    # Pour tester sans cramer de quota Let's Encrypt, dé-commenter :
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ─────────────────────────────────────────────────────────────────────────────
# API FastAPI (Ray) — endpoint principal + endpoints OIDC (/auth/*)
# ─────────────────────────────────────────────────────────────────────────────
api.openrag-mirai.numerique-interieur.com {
    encode zstd gzip

    # Préserver les en-têtes upstream pour la détection HTTPS derrière proxy
    # (cf. PR #331 upstream — fix(auth): detect HTTPS behind TLS-terminating reverse proxy).
    reverse_proxy localhost:8080 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Real-IP {remote_host}
    }

    # Logs structurés JSON pour ingestion Loki/Grafana
    log {
        output file /var/log/caddy/api.log
        format json
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# Indexer admin UI (Vite static, port 3042)
# ─────────────────────────────────────────────────────────────────────────────
indexer.openrag-mirai.numerique-interieur.com {
    encode zstd gzip

    reverse_proxy localhost:3042 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }

    log {
        output file /var/log/caddy/indexer.log
        format json
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# Chat (Chainlit) — redirect 301 vers /chainlit/ sur le canonical api.…
#
# Pourquoi pas un reverse_proxy direct vers localhost:8080 :
# OpenRAG pose son cookie de session OIDC sur l'host qui sert /auth/login.
# Si chat.openrag-mirai.numerique-interieur.com sert /auth/login lui-même,
# le cookie est posé sur ce host. Mais OIDC_REDIRECT_URI pointe sur
# api.openrag-mirai/auth/callback → le browser n'envoie pas le cookie au
# callback → erreur "OIDC state cookie missing".
# Solution : router tout le trafic chat vers le canonical api.openrag-mirai/chainlit
# avant que l'utilisateur ait un cookie. Le cookie de session est alors
# posé une seule fois sur api.openrag-mirai et reste consistant pour
# toute la session Chainlit.
# ─────────────────────────────────────────────────────────────────────────────
chat.openrag-mirai.numerique-interieur.com {
    redir https://api.openrag-mirai.numerique-interieur.com/chainlit{uri} permanent
}

# Note : pas de bloc catch-all ``*.openrag-mirai.numerique-interieur.com`` —
# Caddy 2.x rejette ``tls { on_demand }`` sans ``permission module``
# (mécanisme anti-abus qui demande une whitelist d'hôtes ou un endpoint
# ``ask=…`` pour autoriser l'émission de certs LE à la volée).
# Conséquence : un Host header non listé reçoit 421 Misdirected Request
# au lieu d'un 404 maquillé. Acceptable — la liste explicite des vhosts
# est la source de vérité.

# ═════════════════════════════════════════════════════════════════════════════
# Domaine non-canonical : fake-domain.name → redirect 301 permanent
# vers le canonical numerique-interieur.com.
#
# Pourquoi un redirect plutôt qu'un proxy direct sur les 2 domaines :
# OpenRAG a un seul `OIDC_REDIRECT_URI`, un seul `INDEXERUI_URL`, et les
# cookies de session sont liés à un domaine. Servir les 2 hôtes en proxy
# casserait le cookie après le passage par Keycloak. Le redirect 301
# garantit qu'avant tout cookie/auth, le client est sur le canonical.
#
# Historique de bascule : à l'origine `fake-domain.name` était canonical
# (phase de test, DNS Scaleway sous la main). Bascule vers
# `numerique-interieur.com` une fois la zone production prête. Le client
# Keycloak whitelist les 12 redirect URIs des 2 domaines, donc la bascule
# se fait sans modif SSO.
# ═════════════════════════════════════════════════════════════════════════════

api.openrag-mirai.fake-domain.name {
    redir https://api.openrag-mirai.numerique-interieur.com{uri} permanent
}

indexer.openrag-mirai.fake-domain.name {
    redir https://indexer.openrag-mirai.numerique-interieur.com{uri} permanent
}

chat.openrag-mirai.fake-domain.name {
    redir https://chat.openrag-mirai.numerique-interieur.com{uri} permanent
}

# Idem côté fake-domain.name : pas de catch-all on_demand pour la même
# raison (Caddy 2.x exige un permission module).
