# ============================================================================
# OpenRAG — déploiement VM openrag-01-et (51.159.184.192)
# IA externalisée vers le hub Mirai (LiteLLM), SSO Keycloak Mirai,
# DNS sous-zone openrag-mirai.fake-domain.name (Scaleway).
#
# Copier en .env sur la VM dans /opt/openrag/.env, remplir les secrets
# (placeholders <…>) et adapter selon les besoins. Ne jamais committer
# le .env réel.
# ============================================================================

# -----------------------------------------------------------------------------
# 1. LLM principal (LiteLLM proxy → mistral-small-24b)
# -----------------------------------------------------------------------------
BASE_URL=https://llm.api.ai.numerique-interieur.com/v1
API_KEY=<litellm-api-key — voir /root/hub-llm.txt section litellm sur la VM>            # clé LiteLLM (cf. /root/hub-llm.txt sur la VM)
MODEL=mistral-small-24b

# -----------------------------------------------------------------------------
# 2. VLM — Scaleway Generative API (projet EricTiquet, key dédiée openrag-mirai)
#    Le hub Mirai n'expose pas de VLM ; Scaleway fournit pixtral-12b-2409 et
#    mistral-small-3.2-24b-instruct-2506 (cohérent avec le LLM Mirai).
#    Le secretKey est dans /root/hub-llm.txt sur la VM (section scaleway-genai).
# -----------------------------------------------------------------------------
VLM_BASE_URL=https://api.scaleway.ai/a9158aac-8404-46ea-8bf5-1ca048cd6ab4/v1
VLM_API_KEY=<scaleway secretKey, cf. /root/hub-llm.txt>
VLM_MODEL=mistral-small-3.2-24b-instruct-2506
# Alternative plus légère :
# VLM_MODEL=pixtral-12b-2409

# -----------------------------------------------------------------------------
# 3. Embedder (LiteLLM → bge-multilingual-gemma2, dim=3584, multilingue FR-EN)
# -----------------------------------------------------------------------------
EMBEDDER_MODEL_NAME=bge-multilingual-gemma2
EMBEDDER_BASE_URL=https://llm.api.ai.numerique-interieur.com/v1
EMBEDDER_API_KEY=<litellm-api-key — voir /root/hub-llm.txt section litellm sur la VM>   # même clé LiteLLM

# -----------------------------------------------------------------------------
# 4. Reranker (LiteLLM /v1/rerank Cohere-compat sur le même modèle bge)
# -----------------------------------------------------------------------------
RERANKER_ENABLED=true
RERANKER_PROVIDER=openai            # provider Cohere-compat OpenAI (LiteLLM)
RERANKER_BASE_URL=https://llm.api.ai.numerique-interieur.com/v1
RERANKER_API_KEY=<litellm-api-key — voir /root/hub-llm.txt section litellm sur la VM>
RERANKER_MODEL=bge-multilingual-gemma2

# -----------------------------------------------------------------------------
# 5. Transcription — Scaleway Generative API (whisper-large-v3)
#    Choix Scaleway plutôt que Kevent Mirai : le token Kevent fourni n'a pas
#    les droits audio sur son consumer_group. Scaleway expose whisper-large-v3
#    via la même clé que VLM/embedder (un seul secret à gérer).
#
#    /!\ Trois variables sont nécessaires en plus des TRANSCRIBER_* pour que
#    OpenRAG bascule effectivement sur l'API Scaleway au lieu du WhisperActor
#    local (qui est par défaut câblé via conf/config.yaml file_loaders.* ->
#    LocalWhisperLoader). Sans AUDIOLOADER override, l'env TRANSCRIBER_BASE_URL
#    seul est ignoré pour la transcription.
# -----------------------------------------------------------------------------
TRANSCRIBER_BASE_URL=https://api.scaleway.ai/a9158aac-8404-46ea-8bf5-1ca048cd6ab4/v1
TRANSCRIBER_API_KEY=<scaleway secretKey, cf. /root/hub-llm.txt>
TRANSCRIBER_MODEL=whisper-large-v3

# Override file_loaders.{wav,mp3,flac,ogg,aac,flv,wma,mp4} -> OpenAIAudioLoader
# (sans cette var, le yaml par défaut force LocalWhisperLoader = faster-whisper
# CPU/GPU local — 10× plus lent que Scaleway).
AUDIOLOADER=OpenAIAudioLoader

# Détection de langue : par défaut OpenAIAudioLoader fait un pré-pass de 30s
# avec WhisperActor local pour détecter la langue, puis envoie le tout à
# l'API. Sur CPU sans GPU, le pré-pass ajoute 5-10s par fichier ; on peut
# désactiver et laisser Scaleway tout faire (whisper-large-v3 détecte la
# langue tout seul).
USE_WHISPER_LANG_DETECTOR=false

# -----------------------------------------------------------------------------
# 6. Retriever
# -----------------------------------------------------------------------------
RETRIEVER_TOP_K=20

# -----------------------------------------------------------------------------
# 6.bis Sources inline dans le content (pour Open WebUI / LibreChat / clients
# OpenAI-compat qui ignorent le champ `extra`). Quand activé, OpenRAG ajoute
# un bloc markdown "Sources :" en fin de message visible. Le champ `extra`
# (JSON) continue d'être émis pour les clients qui le consomment.
# Désactivé par défaut (zéro changement de contrat OpenAI). À activer pour
# le déploiement Mirai car OWUI 0.9.2 ignore `extra` au top-level.
# -----------------------------------------------------------------------------
INLINE_SOURCES_IN_CONTENT=true
INLINE_SOURCES_TOP_K=5
INLINE_SOURCES_MIN_SCORE=0.0

# -----------------------------------------------------------------------------
# 7. Prompts
# -----------------------------------------------------------------------------
PROMPTS_DIR=../prompts/example1

# -----------------------------------------------------------------------------
# 8. Ray
# -----------------------------------------------------------------------------
RAY_DEDUP_LOGS=0
RAY_ENABLE_RECORD_ACTOR_TASK_LOGGING=1
RAY_task_retry_delay_ms=3000
RAY_ENABLE_UV_RUN_RUNTIME_ENV=0

# -----------------------------------------------------------------------------
# 9. URLs publiques (derrière Caddy)
# -----------------------------------------------------------------------------
INCLUDE_CREDENTIALS=false
INDEXERUI_PORT=3042
INDEXERUI_URL=https://indexer.openrag-mirai.fake-domain.name
API_BASE_URL=https://api.openrag-mirai.fake-domain.name
APP_PORT=8080

# -----------------------------------------------------------------------------
# 10. Logging / serveur
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
PREFERRED_URL_SCHEME=https

# -----------------------------------------------------------------------------
# 11. Authentication — OIDC Keycloak Mirai
# -----------------------------------------------------------------------------
AUTH_MODE=oidc

# Flow login interactif (auth code + PKCE) — sessions cookies
OIDC_ENDPOINT=https://sso.mirai.interieur.gouv.fr/realms/mirai
OIDC_CLIENT_ID=openrag
OIDC_CLIENT_SECRET=<récupéré dans la console Keycloak après import du client>
OIDC_REDIRECT_URI=https://api.openrag-mirai.fake-domain.name/auth/callback
OIDC_SCOPES=openid email profile offline_access

# Auto-provisioning des utilisateurs au premier login OIDC (cf. PR #341
# upstream linagora/openrag : feat(auth): optional auto-provisioning of
# OIDC users on first login). Default upstream = false (pré-provisioning
# manuel via POST /users/). Sur le déploiement Mirai où l'IdP Keycloak
# est la source de vérité, on active à true : tout user qui se connecte
# est créé en non-admin avec son nom + email depuis les claims.
OIDC_AUTO_PROVISION_LOGIN=true

# Validateur bearer JWT (resource-server) — pour les tokens propagés par
# d'autres clients Keycloak (ex. Open WebUI -> OpenRAG). Active le module
# openrag/auth/oidc.py qui valide la signature JWT, l'issuer et l'audience.
# OIDC_AUDIENCE doit correspondre à l'audience que les autres clients
# mettent dans leur token (ex. mapper "openrag audience" côté open-webui).
OIDC_ISSUER_URL=https://sso.mirai.interieur.gouv.fr/realms/mirai
OIDC_AUDIENCE=openrag

# Group sync (Keycloak -> OpenRAG partitions)
# OIDC_GROUP_CLAIM=groups
# OIDC_GROUP_PREFIX_VIEWER=rag-query/
# OIDC_GROUP_PREFIX_EDITOR=rag-edit/
# OIDC_GROUP_PREFIX_OWNER=rag-admin/
# OIDC_GROUP_SYNC_MODE=additive   # ou 'authoritative'
# OIDC_AUTO_PROVISION=true

# Generate once : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OIDC_TOKEN_ENCRYPTION_KEY=<générée localement par VM>

# OIDC_POST_LOGOUT_REDIRECT_URI=  # optionnel — pointer hors OpenRAG sinon boucle
OIDC_CLAIM_SOURCE=id_token
OIDC_CLAIM_MAPPING=display_name:name,email:email

# -----------------------------------------------------------------------------
# 12. RBAC / quotas
# -----------------------------------------------------------------------------
SUPER_ADMIN_MODE=false
DEFAULT_FILE_QUOTA=100
# AUTH_TOKEN reste utile pour les appels admin programmatiques (création
# d'utilisateurs, scripts CI, etc.) même en mode oidc.
AUTH_TOKEN=<sk-openrag-admin-...>

# -----------------------------------------------------------------------------
# 13. Web search — désactivé par défaut (pas de provider configuré)
# -----------------------------------------------------------------------------
# WEBSEARCH_API_TOKEN=
# WEBSEARCH_BASE_URL=https://api.staan.ai/search/web
# WEBSEARCH_TOP_K=5
# WEBSEARCH_LANG=fr-FR
