# Ignore environment files (secrets — never commit)
.env
.env.local
.env.production
.env.*.local
*.secret
*-secret
*-secret.*
credentials.json
credentials.yaml
credentials.yml
**/scw-key*.json
**/oidc-secret*

# generated files and folders
.files/
.chainlit/
# Allow our custom Chainlit translation overrides (deployment-specific UX
# customizations only — the other locale files are upstream Chainlit defaults
# and re-generate on first run, no need to commit).
!openrag/.chainlit/
!openrag/.chainlit/translations/
!openrag/.chainlit/translations/en-US.json
**/*chainlit.md
.venv/
qdrant_storage/
vdb/volumes

# other files and folders
misc
tmp

# Ignore __pycache__ directories
__pycache__/
**/__pycache__/

**/*upload_dir

# Ignore some local files
*.ipynb
**/*.ipynb


# Ignore Python bytecode files
*.pyc
*.pyo
*.csv

.venv/
model_weights/
model_weights/*
!model_weights/.gitkeep # Keep the placeholder

data/
data/*
!data/.gitkeep

ray_mount

**/*.env.compose
kotaemon
./temps_img
.python-version
.vscode
.DS_Store
logs/
old_logs/

data2/

*.db
test2/

volumes/
volumes/*
!volumes/.gitkeep # Keep the placeholder

# services
services/
services/*
!services/.gitkeep # Keep the placeholder

*.csv
*.pkl

